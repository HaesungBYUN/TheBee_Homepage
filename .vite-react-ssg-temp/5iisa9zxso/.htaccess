<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # [중요] index.html 파일 자체에 대한 요청은 무조건 통과 (무한 루프 방지)
  RewriteRule ^index\.html$ - [L]

  # 1. 존재하지 않는 .php 요청 처리 (이미 작성하신 부분 유지 및 보완)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule \.php$ /index.html [L]

  # 2. 실제 파일이나 폴더가 존재하면 그대로 통과
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. 그 외 모든 요청(careers22 등)을 index.html로 보냄
  # 점(.) 대신 모든 요청(.*)을 명시하고 앞에 /를 붙여주세요.
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>