<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. 실제 파일이나 폴더가 존재하면 그대로 로드 (이미지, JS, CSS 등)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. [SSG] 폴더 내 index.html이 있으면 응답 (마지막 슬래시 유무와 상관없이 처리)
  # 예: /about 또는 /about/ 접속 시 /about/index.html 응답
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ $1/index.html [L]

  # 3. [SPA] 존재하지 않는 모든 경로(오타 등)는 무조건 메인 index.html로 연결
  # '/'를 포함하여 모든 요청(.)을 잡되, 무한 루프 방지를 위해 index.html은 제외
  RewriteRule ^index\.html$ - [L]
  RewriteRule . index.html [L]
</IfModule>

# 비상용 404 설정: 서버 레벨의 에러도 루트의 index.html이 처리하도록 강제
ErrorDocument 404 /index.html